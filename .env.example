# Logging / runtime
FASTLANE_MCP_LOG_LEVEL=INFO
FASTLANE_MCP_TIMEOUT_SECONDS=1800

# App defaults
FASTLANE_MCP_PROJECT_ROOT=/absolute/path/to/your/react-native-app
FASTLANE_MCP_ANDROID_DIR=android
FASTLANE_MCP_PACKAGE_NAME=com.example.app
FASTLANE_MCP_DEFAULT_TRACK=internal

# Artifact discovery
FASTLANE_MCP_AAB_GLOB=android/app/build/outputs/bundle/**/*.aab
FASTLANE_MCP_APK_GLOB=android/app/build/outputs/apk/**/*.apk

# Google Play auth
GOOGLE_PLAY_JSON_KEY_FILE=/absolute/path/to/play-service-account.json
# Alternative to GOOGLE_PLAY_JSON_KEY_FILE:
# GOOGLE_PLAY_JSON_KEY_CONTENT={"type":"service_account","project_id":"..."}

# Optional Fastlane MCP auth aliases
FASTLANE_MCP_PLAY_JSON_KEY_FILE=${GOOGLE_PLAY_JSON_KEY_FILE}
FASTLANE_MCP_PLAY_DEFAULT_LANGUAGE=en-US

# Metadata roots. Point all three at the same supply-compatible metadata root
# unless you have a specific reason to separate them.
FASTLANE_MCP_PLAY_METADATA_DIR=fastlane/metadata/android
FASTLANE_MCP_PLAY_IMAGES_DIR=fastlane/metadata/android
FASTLANE_MCP_PLAY_CHANGELOGS_DIR=fastlane/metadata/android

# Gradle defaults
FASTLANE_MCP_GRADLE_BUILD_AAB_TASK=bundleRelease
FASTLANE_MCP_GRADLE_BUILD_APK_TASK=assembleRelease

# Upload defaults
FASTLANE_MCP_DEFAULT_CHANGES_NOT_SENT_FOR_REVIEW=true
FASTLANE_MCP_DEFAULT_SKIP_UPLOAD_METADATA=false
FASTLANE_MCP_DEFAULT_SKIP_UPLOAD_IMAGES=false
FASTLANE_MCP_DEFAULT_SKIP_UPLOAD_CHANGELOGS=false
